{
    "name": "vecfleet/automation-test",
    "description": "Suite de tests automatizados para la API de VecFleet",
    "type": "project",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "fakerphp/faker": "^1.24"
    },
    "autoload": {
        "psr-4": {
            "VecfleetTests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml --testdox",
        "test:auth": "vendor/bin/phpunit --configuration phpunit.xml --filter Auth --testdox",
        "test:tickets": "vendor/bin/phpunit --configuration phpunit.xml --filter Tickets --testdox",
        "test:moviles": "vendor/bin/phpunit --configuration phpunit.xml --filter Moviles --testdox",
        "test:combustibles": "vendor/bin/phpunit --configuration phpunit.xml --filter Combustibles --testdox"
    }
}
