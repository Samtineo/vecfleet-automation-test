# Entorno target para ejecutar los tests
# Opciones: vec-dev | vec-hotfix | dinant-test | teco-test | bat-mx | heineken
ENVIRONMENT=vec-dev

# URL base del entorno seleccionado
API_URL=https://vec-dev.vecfleet.io/ws/Public/index.php/api

# Credenciales del usuario de prueba (nunca commitear el .env real)
TEST_USERNAME=
TEST_PASSWORD=

# Timeout de requests HTTP en segundos
HTTP_TIMEOUT=30
